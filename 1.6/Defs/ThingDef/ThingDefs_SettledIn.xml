<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- TradingDepot -->
  <ThingDef ParentName="BuildingBase">
    <defName>TradingDepot</defName>
    <label>trading depot</label>
    <description>Trading depots need to be placed near the settlement heart and can be used to continuously sell or buy goods.</description>
    <thingClass>DanielRenner.SettledIn.Building_TradeDepot</thingClass>
    <graphicData>
      <texPath>Building_TradeDepot/TradeDepot</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(3,5)</drawSize>
      <drawOffset>(0,0,0)</drawOffset>
      <color>(96,114,95)</color>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <tickerType>Normal</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <!-- <castEdgeShadows>false</castEdgeShadows>
    <staticSunShadowHeight>0.35</staticSunShadowHeight>
    <fillPercent>0.5</fillPercent> -->
    <canOverlapZones>false</canOverlapZones>
    <pathCost>42</pathCost>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>1800</WorkToBuild>
      <Mass>20</Mass>
      <Flammability>0.5</Flammability>
    </statBases>
    <size>(3,3)</size>
    <costList>
      <Steel>200</Steel>
    </costList>
    <building>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <!-- <researchPrerequisites>
      <li>ComplexFurniture</li>
    </researchPrerequisites> -->
    <designationCategory>DesignationCategory_SettledIn</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <comps>
      <li Class="DanielRenner.SettledIn.CompProperties_SettlementLevelRequired">
        <MinSettlementLevel>3</MinSettlementLevel>
      </li>
      <li Class="DanielRenner.SettledIn.CompProperties_TradingDepotRefuelable">
        <fuelFilter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </fuelFilter>
        <fuelConsumptionRate>0</fuelConsumptionRate>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <consumeFuelOnlyWhenUsed>false</consumeFuelOnlyWhenUsed>
        <canEjectFuel>true</canEjectFuel>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <fuelCapacity>20.0</fuelCapacity>
      </li>
      <!--
      <li Class="DanielRenner.SettledIn.CompProperties_AdjustableFacility">
        <maxSimultaneous>1</maxSimultaneous>
        <maxDistance>25</maxDistance>
        <maxDistanceFrom>5</maxDistanceFrom>
        <requiresLOS>false</requiresLOS>
        <statOffsets>
          <WorkTableWorkSpeedFactor>0.06</WorkTableWorkSpeedFactor>
        </statOffsets>
      </li>
      -->
    </comps>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <drawPlaceWorkersWhileInstallBlueprintSelected>true</drawPlaceWorkersWhileInstallBlueprintSelected>
    <placeWorkers>
      <li>DanielRenner.SettledIn.PlaceWorker_MinSettlementLevel</li>
      <li>DanielRenner.SettledIn.PlaceWorker_UniqueOnMap</li>
      <!-- <li>PlaceWorker_ShowFacilitiesConnections</li> -->
      <!-- <li>DanielRenner.SettledIn.PlaceWorker_ShowAdjustableFacilitiesRange</li>-->
      <li>DanielRenner.SettledIn.PlaceWorker_NextToSettlementCenter</li>
    </placeWorkers>
  </ThingDef>
  <!-- SettledIn_ProductionCenter -->
  <ThingDef ParentName="BuildingBase">
    <defName>SettledIn_ProductionCenter</defName>
    <label>production center marker</label>
    <description>Marks the heart of the settlements production facilities. Improves work facilities, but also worsens living conditions nearby. Can only be built once per map and has a adjustable effect radius.</description>
    <graphicData>
      <texPath>Building_Pillar/Building_Pillar</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,2)</drawSize>
      <color>(96,114,95)</color>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <castEdgeShadows>false</castEdgeShadows>
    <staticSunShadowHeight>0.35</staticSunShadowHeight>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <pathCost>42</pathCost>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>1800</WorkToBuild>
      <Mass>20</Mass>
      <Flammability>0.5</Flammability>
    </statBases>
    <size>(1,1)</size>
    <costList>
      <Steel>200</Steel>
    </costList>
    <building>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
    </building>
    <!-- <researchPrerequisites>
      <li>ComplexFurniture</li>
    </researchPrerequisites> -->
    <designationCategory>DesignationCategory_SettledIn</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <comps>
      <li Class="DanielRenner.SettledIn.CompProperties_SettlementLevelRequired">
        <MinSettlementLevel>3</MinSettlementLevel>
      </li>
      <li Class="DanielRenner.SettledIn.CompProperties_AdjustableFacility">
        <maxSimultaneous>1</maxSimultaneous>
        <maxDistance>25</maxDistance>
        <maxDistanceFrom>5</maxDistanceFrom>
        <requiresLOS>false</requiresLOS>
        <statOffsets>
          <WorkTableWorkSpeedFactor>0.25</WorkTableWorkSpeedFactor>
          <RestRateMultiplier>0.85</RestRateMultiplier>
          <ResearchSpeed>0.85</ResearchSpeed>
          <BedRestEffectiveness>0.85</BedRestEffectiveness>
        </statOffsets>
      </li>
    </comps>
    <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
    <drawPlaceWorkersWhileInstallBlueprintSelected>true</drawPlaceWorkersWhileInstallBlueprintSelected>
    <placeWorkers>
      <li>DanielRenner.SettledIn.PlaceWorker_MinSettlementLevel</li>
      <li>DanielRenner.SettledIn.PlaceWorker_UniqueOnMap</li>
      <!-- <li>PlaceWorker_ShowFacilitiesConnections</li> -->
      <li>DanielRenner.SettledIn.PlaceWorker_ShowAdjustableFacilitiesRange</li>
    </placeWorkers>
  </ThingDef>
