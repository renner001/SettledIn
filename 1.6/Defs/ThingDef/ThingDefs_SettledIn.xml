  <!-- WardeningSpot -->
  <ThingDef ParentName="BuildingBase">
    <defName>WardeningSpot</defName>
    <label>wardening spot</label>
    <thingClass>DanielRenner.SettledIn.Building_TableSettlementOffice</thingClass>
    <description>A spot for standing guard at. Standing guard here improves the settlement buffer.</description>
