  <!-- SettlementCenter -->
  <ThingDef ParentName="FurnitureWithQualityBase" Class="DanielRenner.SettledIn.Building_SettlementCenterDef">
    <defName>SettlementCenter</defName>
    <label>settlement center</label>
    <description>The centerpiece monument to represent the glorious achievements of your settlement.</description>
    <thingClass>DanielRenner.SettledIn.Building_SettlementCenter</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Building_SettlementCenter/SettlementCenter</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(7,7)</drawSize>
      <shaderType>Cutout</shaderType>
      <!-- <color>(0.0,0.0,0.0,0.0)</color> -->
      <!--<shadowData>
        <volume>(6.03,1.0,5.25)</volume>
        <offset>(0,0,-0.25)</offset>
      </shadowData>-->
      <damageData>
        <rect>(0.3,0,5.4,6)</rect>
      </damageData>
      <!--<shadowData/>-->
    </graphicData>
    <blockWind>true</blockWind>
    <blockLight>false</blockLight>
    <castEdgeShadows>false</castEdgeShadows>
    <!--<staticSunShadowHeight>1.0</staticSunShadowHeight>-->
    <altitudeLayer>Building</altitudeLayer>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,1)</interactionCellOffset>
    <!--<passability>Impassable</passability>-->
    <pathCost>80</pathCost>
    <scatterableOnMapGen>false</scatterableOnMapGen>
    <fillPercent>1</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <Mass>750</Mass>
      <MaxHitPoints>5000</MaxHitPoints>
      <WorkToBuild>1</WorkToBuild>
      <Flammability>0.0</Flammability>
      <Beauty>50</Beauty>
      <JoyGainFactor>0.8</JoyGainFactor>
    </statBases>
    <tickerType>Normal</tickerType>
    <size>(5,5)</size>
    <rotatable>false</rotatable>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <designationCategory>DesignationCategory_SettledIn</designationCategory>
    <!--<designationHotKey>Misc6</designationHotKey>-->
    <!--<constructionSkillPrerequisite>0</constructionSkillPrerequisite>-->
    <!-- <stuffCategories>
      <li>Metallic</li>
      <li>Stony</li>
    </stuffCategories>
    <costStuffCount>1</costStuffCount>-->
    <costList />
    <comps>
      <li Class="DanielRenner.SettledIn.CompProperties_GlobalSettlementEffects"></li>
      <li Class="DanielRenner.SettledIn.CompProperties_ClickBaiter"></li>
      <li Class="DanielRenner.SettledIn.CompProperties_UpgradeSettlement"></li>
      <li Class="DanielRenner.SettledIn.CompProperties_AggregatedArt">
        <nameMaker>NamerArtFurniture</nameMaker>
        <descriptionMaker>ArtDescription_Furniture</descriptionMaker>
        <minQualityForArtistic>Awful</minQualityForArtistic>
        <canBeEnjoyedAsArt>true</canBeEnjoyedAsArt>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>7</glowRadius>
        <glowColor>(255,255,255,0)</glowColor>
      </li>
    </comps>
    <placeWorkers>
      <li>DanielRenner.SettledIn.PlaceWorker_UniqueOnMap</li>
    </placeWorkers>
    <building>
      <joyKind>Meditative</joyKind>
      <ai_chillDestination>true</ai_chillDestination>
    </building>
    <inspectorTabs>
      <li>DanielRenner.SettledIn.ITab_AggregatedArt</li>
    </inspectorTabs>
    <specialDisplayRadius>10.9</specialDisplayRadius>
  </ThingDef>
